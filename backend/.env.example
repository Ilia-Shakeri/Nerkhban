# Backend runtime
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=true

# PostgreSQL
DATABASE_URL=postgresql+psycopg://nerkhban:nerkhban@localhost:5432/nerkhban

# Auth
JWT_SECRET_KEY=change-this-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# CORS origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Pricing providers
GOLD_API_BASE_URL=https://api.gold-api.com
ALANCHAND_API_BASE_URL=https://api.alanchand.com
ALANCHAND_API_TOKEN=
TGJU_API_BASE_URL=https://api.tgju.org/v1
NOBITEX_API_BASE_URL=https://api.nobitex.ir
TETHERLAND_API_BASE_URL=https://api.tetherland.com
BONBAST_API_BASE_URL=https://www.bonbast.com
COINGECKO_API_BASE_URL=https://api.coingecko.com/api/v3
COINCAP_API_BASE_URL=https://api.coincap.io/v2
METALS_DEV_API_BASE_URL=https://api.metals.dev/v1
METALS_DEV_API_KEY=
GOLDAPI_API_KEY=
EXCHANGERATE_API_BASE_URL=https://v6.exchangerate-api.com/v6
EXCHANGERATE_API_KEY=
FRANKFURTER_API_BASE_URL=https://api.frankfurter.app

# Fallback exchange-rate provider
EXCHANGE_RATE_API_BASE_URL=https://open.er-api.com/v6/latest
PRICE_CACHE_FILE=price_cache.json
PRICING_REQUIRE_PROVIDER_KEYS=false
